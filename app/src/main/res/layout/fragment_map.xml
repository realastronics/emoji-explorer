<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top HUD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="#E6000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tv_team_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Team"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/score_badge"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="0 pts"
            android:textColor="#EF9F27"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Proximity ring pulse -->
    <View
        android:id="@+id/proximity_ring"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="center"
        android:background="@drawable/proximity_ring"
        android:visibility="gone" />

    <!-- Direction arrow to nearest emoji -->
    <LinearLayout
        android:id="@+id/arrow_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="200dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_direction_arrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="▲"
            android:textColor="#E8002D"
            android:textSize="36sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_direction_dist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50m"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Bottom card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Rarity legend row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Common"
                android:textColor="#888780"
                android:textSize="11sp"
                android:paddingEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Uncommon"
                android:textColor="#378ADD"
                android:textSize="11sp"
                android:paddingEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Rare"
                android:textColor="#7F77DD"
                android:textSize="11sp"
                android:paddingEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Ultra"
                android:textColor="#EF9F27"
                android:textSize="11sp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_nearest_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Move to find emojis"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <!-- Capture button — hidden until in range -->
        <Button
            android:id="@+id/btn_open_ar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#7F77DD"
            android:text="CAPTURE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_leaderboard"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:backgroundTint="#222222"
            android:text="Leaderboard"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>