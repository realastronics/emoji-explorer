<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Direction arrow — top right -->
    <LinearLayout
        android:id="@+id/arrow_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="70dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/arrow_circle_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_direction_arrow"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="➤"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_direction_dist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="50m"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Blackout overlay — shown when team is attacked -->
    <FrameLayout
        android:id="@+id/blackout_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textColor="#E8002D"
                android:textSize="64sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tv_blackout_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="YOU HAVE BEEN ATTACKED"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_blackout_attacker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by Team Alpha"
                android:textColor="#E8002D"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_blackout_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="7"
                android:textColor="#666666"
                android:textSize="32sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Right side buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="200dp"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/btn_compass"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/map_btn_bg"
            android:layout_marginBottom="10dp">
            <TextView
                android:id="@+id/tv_compass_arrow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="⬆"
                android:textColor="#FFFFFF"
                android:textSize="20sp"/>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_recenter"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/map_btn_bg">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="⊙"
                android:textColor="#FFFFFF"
                android:textSize="20sp"/>
        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="top"
        android:background="#F0000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emoji Explorer"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/tv_team_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Team"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/score_badge"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:text="0 pts"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Capture stats -->
    <TextView
        android:id="@+id/tv_capture_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="180dp"
        android:background="@drawable/stats_badge_bg"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="0 / 12"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"/>


    <!-- Bottom left radar widget -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="160dp"
        android:background="@drawable/radar_widget_bg"
        android:orientation="vertical"
        android:padding="10dp">

        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal">
            <View
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/radar_ring"/>
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:background="@drawable/radar_ring"/>

            <View
                android:id="@+id/proximity_ring"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/proximity_ring" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="◉"
                android:textColor="#00FFCC"
                android:textSize="20sp"/>
        </FrameLayout>

        <TextView
            android:id="@+id/tv_detected_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:background="@drawable/detected_badge_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="DETECTED: 0"
            android:textColor="#00FFCC"
            android:textSize="10sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_closest_dist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:background="@drawable/closest_badge_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="Closest: --"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Bottom card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">


        <TextView
            android:id="@+id/tv_nearest_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Move to find emojis"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_open_ar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#7F77DD"
            android:text="CAPTURE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_leaderboard"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:backgroundTint="#222222"
            android:text="Leaderboard"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>