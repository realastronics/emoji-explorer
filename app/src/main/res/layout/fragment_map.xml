<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Radar scan overlay — centred on player -->
    <FrameLayout
        android:id="@+id/radar_container"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:visibility="visible">

        <View
            android:id="@+id/radar_ring_1"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/radar_ring"
            android:alpha="0" />

        <View
            android:id="@+id/radar_ring_2"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/radar_ring"
            android:alpha="0" />

    </FrameLayout>

    <!-- Blackout overlay — shown when team is attacked -->
    <FrameLayout
        android:id="@+id/blackout_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textColor="#E8002D"
                android:textSize="64sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tv_blackout_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="YOU HAVE BEEN ATTACKED"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_blackout_attacker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="by Team Alpha"
                android:textColor="#E8002D"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tv_blackout_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="7"
                android:textColor="#666666"
                android:textSize="32sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Top HUD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="#E6000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E2"
            android:textColor="#E8002D"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingEnd="8dp"/>

        <TextView
            android:id="@+id/tv_team_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Team"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tv_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/score_badge"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="0 pts"
            android:textColor="#E8002D"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Proximity ring pulse -->
    <View
        android:id="@+id/proximity_ring"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="center"
        android:background="@drawable/proximity_ring"
        android:visibility="gone" />

    <!-- Direction arrow -->
    <LinearLayout
        android:id="@+id/arrow_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="200dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_direction_arrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="▲"
            android:textColor="#E8002D"
            android:textSize="36sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_direction_dist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50m"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Capture stats -->
    <TextView
        android:id="@+id/tv_capture_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="180dp"
        android:background="@drawable/stats_badge_bg"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="0 / 12"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"/>

    <!-- Bottom card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bottom_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- Rarity legend row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Common"
                android:textColor="#888780"
                android:textSize="11sp"
                android:paddingEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Uncommon"
                android:textColor="#378ADD"
                android:textSize="11sp"
                android:paddingEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Rare"
                android:textColor="#7F77DD"
                android:textSize="11sp"
                android:paddingEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Ultra"
                android:textColor="#EF9F27"
                android:textSize="11sp"/>

        </LinearLayout>


        <TextView
            android:id="@+id/tv_nearest_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Move to find emojis"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_open_ar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#7F77DD"
            android:text="CAPTURE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_leaderboard"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:backgroundTint="#222222"
            android:text="Leaderboard"
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>