<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera feed -->
    <TextureView
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Scan line overlay — green horizontal line that sweeps down -->
    <View
        android:id="@+id/scan_line"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#AA00FF88"
        android:visibility="gone"/>

    <!-- Corner brackets — top left -->
    <View
        android:layout_width="40dp"
        android:layout_height="3dp"
        android:layout_gravity="center"
        android:layout_marginBottom="120dp"
        android:layout_marginStart="-60dp"
        android:background="#00FF88"/>

    <!-- Emoji floating in AR — large and visible -->
    <TextView
        android:id="@+id/tv_emoji_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="80dp"
        android:text="🔥"
        android:textSize="96sp"
        android:elevation="8dp"/>

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#333333"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tv_ar_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Point camera at the emoji"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tv_ar_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="10 pts"
            android:textColor="#EF9F27"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- AR corner frame brackets -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp">

        <!-- Top-left corner -->
        <View
            android:layout_width="30dp"
            android:layout_height="3dp"
            android:layout_gravity="top|start"
            android:background="#00FF88"/>
        <View
            android:layout_width="3dp"
            android:layout_height="30dp"
            android:layout_gravity="top|start"
            android:background="#00FF88"/>

        <!-- Top-right corner -->
        <View
            android:layout_width="30dp"
            android:layout_height="3dp"
            android:layout_gravity="top|end"
            android:background="#00FF88"/>
        <View
            android:layout_width="3dp"
            android:layout_height="30dp"
            android:layout_gravity="top|end"
            android:background="#00FF88"/>

        <!-- Bottom-left corner -->
        <View
            android:layout_width="30dp"
            android:layout_height="3dp"
            android:layout_gravity="bottom|start"
            android:background="#00FF88"/>
        <View
            android:layout_width="3dp"
            android:layout_height="30dp"
            android:layout_gravity="bottom|start"
            android:background="#00FF88"/>

        <!-- Bottom-right corner -->
        <View
            android:layout_width="30dp"
            android:layout_height="3dp"
            android:layout_gravity="bottom|end"
            android:background="#00FF88"/>
        <View
            android:layout_width="3dp"
            android:layout_height="30dp"
            android:layout_gravity="bottom|end"
            android:background="#00FF88"/>

    </FrameLayout>

    <!-- Reticle -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center">
        <View
            android:id="@+id/reticle_ring"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/reticle_ring"/>
        <View
            android:id="@+id/reticle_fill"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/reticle_fill"
            android:scaleX="0"
            android:scaleY="0"/>
    </FrameLayout>

    <!-- Bottom capture UI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_capture_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Hold CAPTURE to catch it!"
            android:textColor="#FFFFFF"
            android:textSize="14sp"/>

        <!-- Scan status indicator -->
        <TextView
            android:id="@+id/tv_scan_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="● SCANNING"
            android:textColor="#00FF88"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_capture"
                android:layout_width="180dp"
                android:layout_height="56dp"
                android:layout_marginEnd="12dp"
                android:backgroundTint="#130F38"
                android:text="CAPTURE"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn_photo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:backgroundTint="#222222"
                android:text="📷"
                android:textSize="20sp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Success overlay -->
    <LinearLayout
        android:id="@+id/capture_success_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_success_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="96sp"/>

        <TextView
            android:id="@+id/tv_success_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+10 pts!"
            android:textColor="#EF9F27"
            android:textSize="32sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="CAPTURED"
            android:textColor="#00FF88"
            android:textSize="14sp"
            android:letterSpacing="0.3"
            android:fontFamily="monospace"/>

    </LinearLayout>

</FrameLayout>