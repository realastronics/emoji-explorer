<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera feed fills entire screen -->
    <TextureView
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Emoji floating in AR space — centred on screen -->
    <TextView
        android:id="@+id/tv_emoji_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="80dp"
        android:text="🔥"
        android:textSize="72sp" />

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#333333"
            android:text="Back"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_ar_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Point camera at the emoji"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_ar_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="10 pts"
            android:textColor="#EF9F27"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Reticle centre -->
    <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center">

        <View
            android:id="@+id/reticle_ring"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/reticle_ring" />

        <View
            android:id="@+id/reticle_fill"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/reticle_fill"
            android:scaleX="0"
            android:scaleY="0" />

    </FrameLayout>

    <!-- Bottom capture UI -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_capture_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Hold CAPTURE to catch it!"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_capture"
            android:layout_width="180dp"
            android:layout_height="56dp"
            android:backgroundTint="#7F77DD"
            android:text="CAPTURE"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Success overlay -->
    <LinearLayout
        android:id="@+id/capture_success_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_success_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="72sp" />

        <TextView
            android:id="@+id/tv_success_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+10 pts!"
            android:textColor="#EF9F27"
            android:textSize="32sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>