<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <TextureView
        android:id="@+id/arSceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <View
        android:id="@+id/scan_line"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#AA00FF88"
        android:visibility="gone"/>

    <!-- Subtle grid overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/grid_overlay"
        android:alpha="0.04"/>

    <!-- Floating can -->
    <ImageView
        android:id="@+id/iv_can_overlay"
        android:layout_width="72dp"
        android:layout_height="125dp"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        android:scaleType="fitCenter"
        android:elevation="8dp"/>

    <!-- Corner brackets — now a single FrameLayout centered on the can -->
    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp">

        <View android:layout_width="28dp" android:layout_height="2dp"
            android:layout_gravity="top|start" android:background="#00FF88"/>
        <View android:layout_width="2dp" android:layout_height="28dp"
            android:layout_gravity="top|start" android:background="#00FF88"/>
        <View android:layout_width="28dp" android:layout_height="2dp"
            android:layout_gravity="top|end" android:background="#00FF88"/>
        <View android:layout_width="2dp" android:layout_height="28dp"
            android:layout_gravity="top|end" android:background="#00FF88"/>
        <View android:layout_width="28dp" android:layout_height="2dp"
            android:layout_gravity="bottom|start" android:background="#00FF88"/>
        <View android:layout_width="2dp" android:layout_height="28dp"
            android:layout_gravity="bottom|start" android:background="#00FF88"/>
        <View android:layout_width="28dp" android:layout_height="2dp"
            android:layout_gravity="bottom|end" android:background="#00FF88"/>
        <View android:layout_width="2dp" android:layout_height="28dp"
            android:layout_gravity="bottom|end" android:background="#00FF88"/>
    </FrameLayout>

    <!-- Reticle ring only — fill is now the progress bar below -->
    <View
        android:id="@+id/reticle_ring"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center"
        android:layout_marginBottom="60dp"
        android:background="@drawable/reticle_ring"/>

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#333333"
            android:text="&#8592; Back"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"/>

        <TextView
            android:id="@+id/tv_ar_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="Point camera at the can"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tv_ar_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_amber"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="10 pts"
            android:textColor="#EF9F27"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Bottom panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#D0000000"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="28dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tv_scan_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="6dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:text="● SCANNING"
            android:textColor="#00FF88"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/tv_capture_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="10dp"
            android:text="Hold CAPTURE to catch it!"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="monospace"/>

        <!-- Capture progress bar — replaces invisible reticle_fill -->
        <View
            android:id="@+id/reticle_fill"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_marginBottom="14dp"
            android:background="#48FC38"
            android:scaleX="0"
            android:transformPivotX="0dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginBottom="14dp"
            android:layout_marginTop="-18dp"
            android:background="#33FFFFFF"
            android:elevation="0dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_capture"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:layout_marginEnd="10dp"
                android:backgroundTint="#48FC38"
                android:text="CAPTURE"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"/>

            <Button
                android:id="@+id/btn_photo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:backgroundTint="#222222"
                android:text="📷"
                android:textSize="18sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Success overlay -->
    <LinearLayout
        android:id="@+id/capture_success_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#BB000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_success_can"
            android:layout_width="80dp"
            android:layout_height="139dp"
            android:scaleType="fitCenter"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tv_success_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+10 pts!"
            android:textColor="#EF9F27"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="CAPTURED"
            android:textColor="#00FF88"
            android:textSize="13sp"
            android:letterSpacing="0.3"
            android:fontFamily="monospace"/>
    </LinearLayout>

</FrameLayout>