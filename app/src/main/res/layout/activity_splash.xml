<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- F1 red accent bar top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_gravity="top"
        android:background="#C4B9EB" />

    <!-- F1 red accent bar bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_gravity="bottom"
        android:background="#C4B9EB" />

    <!-- Centre content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <!-- App icon placeholder — replace with real icon later -->
        <ImageView
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:src="@drawable/app_logo"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMOJI EXPLORER"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RACE TO CAPTURE"
            android:textColor="#E1DDF0"
            android:textSize="14sp"
            android:letterSpacing="0.3"
            android:layout_marginBottom="48dp"/>

        <!-- Loading bar -->
        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="4dp"
            android:background="#1AFFFFFF">

            <View
                android:id="@+id/loading_bar"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#E8002D" />

        </FrameLayout>

        <TextView
            android:id="@+id/tv_loading_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Starting engine..."
            android:textColor="#666666"
            android:textSize="13sp"/>

    </LinearLayout>

</FrameLayout>